[node name="NPC" parent="NPCs" unique_id=1526380673 instance=ExtResource("7_i8kv5")]
position = Vector2(168, -16)
dialog = Array[String](["Yo waddup.", "I'm the tutorial guy, you know the drill.", "As you've noticed, you can move using WASD and jump with space, but you can also attack with left click, and aim with your mouse", "You can jump on some enemies, but not all of them. If you get hit, just wait a few seconds without taking damage to heal. You can also \"pogo\" on every enemy by attacking them from above.", "Also, keep in mind you can only jump on SOME enemies. You can jump on goombas, for instance, but not on the sword enemies.", "That's all! Have fun."])

[node name="NPC_2" parent="NPCs" unique_id=1650656017 instance=ExtResource("7_i8kv5")]
position = Vector2(1433, -144)
dialog = Array[String](["Watch out for the blue goombas. Those guys STINK!!!", "They don't fall off edges unlike the red ones. Watch out bro...", "Also before you go, pro tip: by pressing jump twice in a row very quickly, you can do a high jump to go farther!", "...Isn't my house cool?"])

